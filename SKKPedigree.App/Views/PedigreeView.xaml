<UserControl x:Class="SKKPedigree.App.Views.PedigreeView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:SKKPedigree.App.Controls">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibility"/>
    </UserControl.Resources>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Toolbar -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="8,6,8,4">
            <TextBlock Text="Pedigree:" VerticalAlignment="Center" Margin="0,0,6,0"/>
            <TextBlock Text="{Binding RootDog.Name}" FontWeight="Bold"
                       VerticalAlignment="Center" Margin="0,0,12,0"/>
            <Button Content="+ Expand all ancestors"
                    Command="{Binding ExpandNodeCommand}"
                    CommandParameter="{Binding Nodes[0]}"
                    Margin="0,0,6,0"/>
            <ProgressBar IsIndeterminate="{Binding IsBusy}" Width="120" Height="8"
                         VerticalAlignment="Center"
                         Visibility="{Binding IsBusy, Converter={StaticResource BoolToVisibility}}"/>
        </StackPanel>

        <!-- Zoomable ScrollViewer containing Canvas -->
        <ScrollViewer Grid.Row="1" HorizontalScrollBarVisibility="Auto"
                      VerticalScrollBarVisibility="Auto">
            <Canvas x:Name="PedigreeCanvas"
                    Width="2400" Height="1600"
                    Background="#FAFAFA"
                    SizeChanged="Canvas_SizeChanged"
                    MouseWheel="Canvas_MouseWheel">

                <!-- Edges drawn as Bezier paths -->
                <ItemsControl x:Name="EdgesControl" Canvas.Left="0" Canvas.Top="0"
                              IsHitTestVisible="False">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <Canvas/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                </ItemsControl>

                <!-- Dog nodes -->
                <ItemsControl x:Name="NodesControl" Canvas.Left="0" Canvas.Top="0">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <Canvas/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemContainerStyle>
                        <Style TargetType="ContentPresenter">
                            <Setter Property="Canvas.Left" Value="{Binding X}"/>
                            <Setter Property="Canvas.Top"  Value="{Binding Y}"/>
                        </Style>
                    </ItemsControl.ItemContainerStyle>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <controls:DogNodeControl Dog="{Binding Dog}"
                                                     IsRoot="{Binding IsRoot}"
                                                     DogSelected="DogNode_Selected"
                                                     ToolTip="{Binding Dog.BirthDate}"/>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </Canvas>
        </ScrollViewer>

        <!-- Status -->
        <TextBlock Grid.Row="2" Text="{Binding Status}"
                   Foreground="#555" FontSize="11" Margin="8,3,8,4"/>
    </Grid>
</UserControl>
