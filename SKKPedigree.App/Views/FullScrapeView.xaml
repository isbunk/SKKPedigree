<UserControl x:Class="SKKPedigree.App.Views.FullScrapeView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibility"/>
        <Style x:Key="StatCard" TargetType="Border">
            <Setter Property="Background" Value="#F8F8F8"/>
            <Setter Property="BorderBrush" Value="#DDD"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="4"/>
            <Setter Property="Padding" Value="12,8"/>
            <Setter Property="Margin" Value="0,0,6,0"/>
        </Style>
        <Style x:Key="StatLabel" TargetType="TextBlock">
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Foreground" Value="#888"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
        </Style>
        <Style x:Key="StatValue" TargetType="TextBlock">
            <Setter Property="FontSize" Value="26"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
        </Style>
    </UserControl.Resources>

    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ── Options & Controls ─────────────────────────────────────────── -->
        <Border Grid.Row="0" Background="#F5F5F5" BorderBrush="#DDD"
                BorderThickness="1" CornerRadius="5" Padding="10,8" Margin="0,0,0,8">
            <StackPanel Orientation="Horizontal">

                <TextBlock Text="Save every" VerticalAlignment="Center" Margin="0,0,4,0"/>
                <TextBox Width="40" Height="26" VerticalContentAlignment="Center"
                         Text="{Binding BatchSize, UpdateSourceTrigger=PropertyChanged}"
                         Margin="0,0,4,0"/>
                <TextBlock Text="dogs" VerticalAlignment="Center" Margin="0,0,16,0"/>

                <TextBlock Text="Log file:" VerticalAlignment="Center" Margin="0,0,4,0"/>
                <TextBox Width="280" Height="26" VerticalContentAlignment="Center"
                         Text="{Binding LogFilePath, UpdateSourceTrigger=LostFocus}"
                         Margin="0,0,4,0" FontSize="11" Foreground="#444"/>
                <Button Content="Open Log Folder"
                        Command="{Binding OpenLogFolderCommand}"
                        Height="26" Padding="6,0" Margin="0,0,16,0"/>

                <Button Content="Start Full Scrape"
                        Command="{Binding StartCommand}"
                        Height="32" Width="150" FontSize="13" FontWeight="SemiBold"
                        Margin="0,0,6,0"/>
                <Button Content="Stop"
                        Command="{Binding StopCommand}"
                        Height="32" Width="70" FontSize="13"/>
            </StackPanel>
        </Border>

        <!-- ── Stats cards ────────────────────────────────────────────────── -->
        <UniformGrid Grid.Row="1" Columns="4" Margin="0,0,0,8">
            <Border Style="{StaticResource StatCard}">
                <StackPanel HorizontalAlignment="Center">
                    <TextBlock Text="Scraped" Style="{StaticResource StatLabel}"/>
                    <TextBlock Text="{Binding ScrapedTotal}" Style="{StaticResource StatValue}"
                               Foreground="#1565C0"/>
                </StackPanel>
            </Border>
            <Border Style="{StaticResource StatCard}">
                <StackPanel HorizontalAlignment="Center">
                    <TextBlock Text="Queued" Style="{StaticResource StatLabel}"/>
                    <TextBlock Text="{Binding QueuedCount}" Style="{StaticResource StatValue}"
                               Foreground="#6A1B9A"/>
                </StackPanel>
            </Border>
            <Border Style="{StaticResource StatCard}">
                <StackPanel HorizontalAlignment="Center">
                    <TextBlock Text="Skipped (fresh)" Style="{StaticResource StatLabel}"/>
                    <TextBlock Text="{Binding SkippedCount}" Style="{StaticResource StatValue}"
                               Foreground="#2E7D32"/>
                </StackPanel>
            </Border>
            <Border Style="{StaticResource StatCard}">
                <StackPanel HorizontalAlignment="Center">
                    <TextBlock Text="Errors" Style="{StaticResource StatLabel}"/>
                    <TextBlock Text="{Binding ErrorCount}" Style="{StaticResource StatValue}"
                               Foreground="#B71C1C"/>
                </StackPanel>
            </Border>
        </UniformGrid>

        <!-- ── Progress bar ───────────────────────────────────────────────── -->
        <StackPanel Grid.Row="2" Margin="0,0,0,8">
            <ProgressBar IsIndeterminate="{Binding IsScraping}" Height="6" Margin="0,0,0,4"/>
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="Status: " Foreground="#888" FontSize="11"/>
                <TextBlock Text="{Binding Status}" FontWeight="SemiBold" FontSize="11" Margin="0,0,12,0"/>
                <TextBlock Text="Now: " Foreground="#888" FontSize="11"/>
                <TextBlock Text="{Binding CurrentDog}" FontSize="11"
                           TextTrimming="CharacterEllipsis" MaxWidth="500"/>
            </StackPanel>
        </StackPanel>

        <!-- ── Log viewer (newest at top) ────────────────────────────────── -->
        <Border Grid.Row="3" BorderBrush="#CCC" BorderThickness="1" CornerRadius="4">
            <ScrollViewer VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Auto">
                <ItemsControl ItemsSource="{Binding LogLines}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding}" FontFamily="Consolas" FontSize="11"
                                       Padding="4,1"/>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Border>

        <!-- ── Bottom status ─────────────────────────────────────────────── -->
        <TextBlock Grid.Row="4" Margin="0,4,0,0" FontSize="11" Foreground="#666">
            <Run Text="Log file: "/>
            <Run Text="{Binding LogFilePath}" FontStyle="Italic"/>
        </TextBlock>
    </Grid>
</UserControl>
