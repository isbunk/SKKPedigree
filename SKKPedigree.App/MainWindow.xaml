<Window x:Class="SKKPedigree.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="clr-namespace:SKKPedigree.App.Views"
        Title="SKK Hunddata — Pedigree Browser"
        Height="750" Width="1200"
        MinHeight="600" MinWidth="900"
        WindowStartupLocation="CenterScreen">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibility"/>
    </Window.Resources>

    <DockPanel>
        <!-- Tab shell -->
        <TabControl x:Name="MainTabs" DockPanel.Dock="Top"
                    SelectionChanged="MainTabs_SelectionChanged">
            <TabItem Header="🔍 Search" x:Name="TabSearch">
                <views:SearchView x:Name="SearchViewControl"/>
            </TabItem>
            <TabItem Header="🌳 Pedigree Tree" x:Name="TabPedigree">
                <views:PedigreeView x:Name="PedigreeViewControl"/>
            </TabItem>
            <TabItem Header="🐾 Litter / Siblings" x:Name="TabLitter">
                <views:LitterView x:Name="LitterViewControl"/>
            </TabItem>
            <TabItem Header="🔗 Relation Finder" x:Name="TabRelation">
                <views:RelationView x:Name="RelationViewControl"/>
            </TabItem>
            <TabItem Header="Full Scraper" x:Name="TabFullScrape">
                <views:FullScrapeView x:Name="FullScrapeViewControl"/>
            </TabItem>
        </TabControl>

        <!-- Status bar -->
        <StatusBar DockPanel.Dock="Bottom" Height="22">
            <StatusBarItem>
                <TextBlock x:Name="StatusText" Text="Ready" FontSize="11"/>
            </StatusBarItem>
            <Separator/>
            <StatusBarItem>
                <TextBlock x:Name="LastUpdatedText" FontSize="11"/>
            </StatusBarItem>
        </StatusBar>
    </DockPanel>
</Window>
